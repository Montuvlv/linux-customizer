{
  "name": "linux-forge",
  "version": "1.0.0",
  "description": "The missing GUI for KDE Plasma customization",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:arm64": "electron-builder --linux --arm64",
    "build:armv7": "electron-builder --linux --armv7l"
  },
  "build": {
    "appId": "com.linuxforge.app",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "System"
    },
    "arm64": {
      "target": "AppImage"
    },
    "armv7l": {
      "target": "AppImage"
    }
  },
  "author": "Montuvlv",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
